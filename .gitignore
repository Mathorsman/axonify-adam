# =============================================================================
# Salesforce Query Tool — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials & secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.sf_token_cache.json        # OAuth access/refresh tokens

# -----------------------------------------------------------------------------
# Runtime data — org-specific, large, regenerated on each run
# -----------------------------------------------------------------------------
sf_backups/                 # CSV backups written before every bulk mutation
sf_logs/                    # Plain-text audit logs
sf_query_log.db             # SQLite query-history database

# -----------------------------------------------------------------------------
# Claude Code — keep project commands, ignore local-only settings
# -----------------------------------------------------------------------------
.claude/settings.local.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# -----------------------------------------------------------------------------
# OS / editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/

# -----------------------------------------------------------------------------
# Jupyter (if ever used for local exploration)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
